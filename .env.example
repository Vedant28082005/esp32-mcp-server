# Copy to .env and fill in your values. Never commit .env.

# ESP32 HTTP API (local network)
ESP32_IP=192.168.1.100
ESP32_TIMEOUT=5

# Public URL when exposing via ngrok (optional; leave empty for local-only)
NGROK_URL=https://your-subdomain.ngrok-free.app

# OAuth stub for Claude.ai remote integration (change in production)
OAUTH_CLIENT_ID=claude_client
OAUTH_CLIENT_SECRET=change-me
OAUTH_ACCESS_TOKEN=change-me
